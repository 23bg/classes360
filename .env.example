# App
NODE_ENV=development

# Security
JWT_SECRET=replace-with-a-32+char-secret

# Database
DATABASE_URL=mongodb://localhost:27017/classes360

# OTP / Rate Limits
OTP_EXPIRY_MINUTES=5
OTP_MAX_RESEND=2
OTP_RATE_LIMIT_PER_MIN=5
LEAD_RATE_LIMIT_PER_MIN=10

# OTP Email (NodeMailer SMTP)
OTP_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Billing (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v19.0

# Optional dashboard/social links
NEXT_PUBLIC_WHATSAPP=
NEXT_PUBLIC_X=
NEXT_PUBLIC_LINKEDIN=

# Optional logging
LOG_LEVEL=info


NEXT_PUBLIC_API_URL=http://classes360.online/api/v1
APP_ROOT_DOMAIN=classes360.online
APP_PORTAL_SUBDOMAIN=portal.classes360.online
APP_STUDENT_SUBDOMAIN=student.classes360.online
SESSION_COOKIE_DOMAIN=classes360.online
CUSTOM_DOMAIN_MAPPINGS=*.classes360.online